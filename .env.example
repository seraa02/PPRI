# ============================================================
# PPRI Survey Processing Pipeline — Configuration Template
# Copy this file to .env and edit the values for your study.
# All processing is FULLY LOCAL. No data leaves this machine.
# ============================================================

# Name of the study (used in the output filename and Excel header)
STUDY_NAME=MockStudy

# Paths to the folders containing scanned survey PDFs
PRE_FOLDER=./PRE
POST_FOLDER=./POST

# Where to save output files (Excel, CSV, logs, checkpoints)
OUTPUT_FOLDER=./output

# Number of PDFs to process per batch before saving a checkpoint
BATCH_SIZE=50

# HuggingFace vision-language model (loaded locally via PyTorch / CUDA)
# Recommended options for a 16 GB T4 GPU:
#   Qwen/Qwen2-VL-2B-Instruct   (~4 GB VRAM) — fast, good accuracy
#   Qwen/Qwen2-VL-7B-Instruct   (~14 GB VRAM) — higher accuracy, tight on T4
#   Qwen/Qwen2.5-VL-3B-Instruct (~6 GB VRAM) — newer architecture
HF_MODEL=Qwen/Qwen2-VL-2B-Instruct

# Tesseract OCR language string
# eng+spa = English + Spanish (bilingual support)
# eng = English only | spa = Spanish only
LANGUAGE=eng+spa

# Confidence threshold: answers below this score are flagged for human review
# Range: 0.0 to 1.0 (recommended: 0.7)
CONFIDENCE_THRESHOLD=0.7

# DPI for PDF-to-image conversion (higher = better quality, slower processing)
# Recommended: 300 for standard forms, 400 for forms with small checkboxes
DPI=300

# ============================================================
# FORM SCHEMAS (strongly recommended — greatly improves accuracy)
# ============================================================
# Paths to YAML files describing the exact questions and answer
# options for each survey type. When set, the AI is given the full
# form structure so it only needs to detect marks — not discover
# questions. This eliminates checkbox misread errors and improves
# accuracy for personal info, numeric, and handwritten fields.
#
# To set up:
#   1. Copy forms/example_pre_schema.yaml  → forms/my_study_pre.yaml
#   2. Copy forms/example_post_schema.yaml → forms/my_study_post.yaml
#   3. Fill in your actual questions, types, and valid options.
#   4. Uncomment and set the paths below.
#
# PRE_SCHEMA_FILE=forms/my_study_pre.yaml
# POST_SCHEMA_FILE=forms/my_study_post.yaml

