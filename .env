# ============================================================
# PPRI Survey Processing Pipeline — Active Configuration
# All processing is FULLY LOCAL. No data leaves this machine.
# ============================================================

# Study name
STUDY_NAME=MockStudy

# Input folders
PRE_FOLDER=./PRE
POST_FOLDER=./POST

# Output folder
OUTPUT_FOLDER=./output

# Batch size
BATCH_SIZE=50

# HuggingFace vision model (runs locally via PyTorch / CUDA)
HF_MODEL=Qwen/Qwen2-VL-2B-Instruct

# OCR language
LANGUAGE=eng+spa

# Confidence threshold
CONFIDENCE_THRESHOLD=0.9

# DPI
DPI=300

# ---- FORM SCHEMAS (schema-aware extraction enabled) ----
PRE_SCHEMA_FILE=forms/falls_prevention_pre.yaml
POST_SCHEMA_FILE=forms/falls_prevention_post.yaml
